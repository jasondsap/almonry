# Resend transactional email (used by /api/request-access)
RESEND_API_KEY=

# Sender used until almonry.app is verified in Resend.
# e.g. hello@made180.com  (falls back to resend's onboarding sender if unset)
RESEND_FROM_FALLBACK=

# Where early-access requests are delivered (Jason's inbox)
NOTIFY_EMAIL=
